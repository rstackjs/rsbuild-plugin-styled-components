{
  "name": "@rsbuild/plugin-styled-components",
  "version": "1.6.3",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-styled-components",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-styled-components#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-styled-components/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "playwright test",
    "bump": "pnpx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "@swc/plugin-styled-components": "^12.13.0",
    "reduce-configs": "^1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@rsbuild/core": "^2.0.15",
    "@rslib/core": "^0.23.0",
    "@rslint/core": "^0.6.2",
    "@types/node": "^24.13.2",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "styled-components": "^6.4.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.7.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.7.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
